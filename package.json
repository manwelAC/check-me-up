{
  "name": "check-me-up",
  "version": "1.0.0",
  "description": "A brutally honest distraction tracker for your terminal",
  "main": "src/main/main.js",
  "type": "module",
  "bin": {
    "check-me": "./bin/check-me.js"
  },
  "scripts": {
    "start": "node bin/check-me.js start",
    "stop": "node bin/check-me.js stop",
    "status": "node bin/check-me.js status",
    "report": "node bin/check-me.js report",
    "gui": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@paymoapp/real-idle": "^1.1.2",
    "active-win": "^8.2.1",
    "chalk": "^5.4.1",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.manwelac.checkmeup",
    "productName": "check-me-up",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "src/assets/check-me-up-logo.ico",
      "target": [
        "portable"
      ]
    },
    "files": [
      "src/**/*",
      "bin/**/*",
      "package.json"
    ],
    "asar": false
  }
}
